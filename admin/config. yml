backend:
  name: git-gateway
  branch: main
media_folder: "images"
collections:
  - name: "produits"
    label: "Produits"
    folder: "contenu"
    create: true
    fields:
      - {label: "Nom", name: "nom", widget: "string"}
      - {label: "Prix", name: "prix", widget: "string"}
      - {label: "Image", name: "image", widget: "image"}
